# =============================================================================
# WeekendStack — Environment Configuration Template
# =============================================================================
#
# QUICK START:
#   Run the interactive setup wizard (recommended):
#     bash setup.sh
#
#   Or for a fully-automated deployment with defaults:
#     bash setup.sh --quick
#
# MANUAL SETUP:
#   Copy this file to .env and fill in your values:
#     cp .env.example .env
#     nano .env
#   Then run: docker compose --profile core up -d
#
# GENERATING SECRETS:
#   openssl rand -hex 32      → 64-char hex (database passwords, JWT secrets)
#   openssl rand -base64 24   → human-friendly password (admin accounts)
#
# SECURITY: Never commit .env to version control — it is gitignored.
# =============================================================================

# =============================================================================
# SECTION 1 — System & Network
# =============================================================================

# Hostname / identifier for this machine
COMPUTER_NAME=weekendstack

# IP address of this Docker host on your local network
# Run "ip -4 addr show | grep inet" to find it
HOST_IP=192.168.1.100                            # <CUSTOMIZE>

# Timezone (used for container timestamps and scheduled tasks)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York                              # <CUSTOMIZE>

# User/group IDs for file ownership (run "id -u" and "id -g" to find yours)
PUID=1000                                        # <CUSTOMIZE>
PGID=1000                                        # <CUSTOMIZE>

# =============================================================================
# SECTION 2 — Domain & Access
# =============================================================================

# Local domain suffix for LAN access (e.g. "lab" → https://glance.lab)
# Requires Pi-hole or manual DNS / /etc/hosts entries + trusting the CA cert.
# Leave blank for IP-only access.
LAB_DOMAIN=lab

# External domain for internet access via Cloudflare Tunnel
# Set to your Cloudflare-managed domain (e.g. example.com)
# Leave as "localhost" if you are not using Cloudflare Tunnel.
BASE_DOMAIN=localhost                            # <CUSTOMIZE> or leave as localhost

# Domain routing mode — set automatically by setup.sh.
# Values: cloudflare | both | pihole | ip
DOMAIN_MODE=ip

# Internal Docker network used by Traefik
TRAEFIK_DOCKER_NETWORK=shared-network

# =============================================================================
# SECTION 3 — Service Profiles
# =============================================================================
# Controls which services are started.
# Managed by setup.sh — edit only if doing a fully manual deployment.
#
# Available base profiles:
#   core          — Traefik, Glance, Vaultwarden, error pages (always recommended)
#   ai            — Ollama, Open WebUI, SearXNG, Whisper, and more
#   dev           — Coder, Gitea, ByteStash, IT-Tools
#   productivity  — Paperless, NocoDB, n8n, Vikunja, Trilium, and more
#   media         — Immich, Navidrome, Kavita
#   personal      — Firefly III, Mealie, wger
#   monitoring    — Uptime Kuma, Netdata, Dozzle, WUD, Duplicati
#   networking    — Traefik, Pi-hole, link-router, cert-generator, error-pages
#   external      — Cloudflare Tunnel container
#   pihole        — Pi-hole + dnsmasq init
#   gpu           — NVIDIA GPU runtime for Ollama / Stable Diffusion
#
COMPOSE_PROFILES=core
SELECTED_PROFILES=core

# =============================================================================
# SECTION 4 — File Storage Paths
# =============================================================================
# Default: use subdirectories inside the repo. Fine for single-machine setups.
# For NFS / shared storage, set these to absolute paths on your mount point.

FILES_BASE_DIR=./files          # User content (photos, music, documents)
DATA_BASE_DIR=./data            # Application databases and runtime state
CONFIG_BASE_DIR=./config        # Configuration files (repo-tracked)
WORKSPACE_DIR=/mnt/workspace    # Coder workspace root (must be absolute)
SSH_KEY_DIR=${CONFIG_BASE_DIR}/ssh

# =============================================================================
# SECTION 5 — Default Admin Credentials
# =============================================================================
# Used during initial provisioning for services that support env-based seeding.
# IMPORTANT: Change DEFAULT_ADMIN_PASSWORD before exposing services publicly!

DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_EMAIL=admin@example.com            # <CUSTOMIZE>
DEFAULT_ADMIN_PASSWORD=                          # <GENERATE> openssl rand -base64 24

# Traefik Basic Auth (for services behind Traefik's auth middleware)
DEFAULT_TRAEFIK_AUTH_USER=admin
DEFAULT_TRAEFIK_AUTH_PASS=                       # <GENERATE> openssl rand -hex 32

# Shared database credentials (used by services that share a Postgres instance)
DEFAULT_DB_USER=dbuser
DEFAULT_DB_PASS=                                 # <GENERATE> openssl rand -hex 32

# Shared secret / key defaults
DEFAULT_JWT_SECRET=                              # <GENERATE> openssl rand -hex 64
DEFAULT_ENCRYPTION_KEY=                          # <GENERATE> openssl rand -hex 32
DEFAULT_APP_SECRET=                              # <GENERATE> openssl rand -hex 32

# =============================================================================
# SECTION 6 — Networking: Traefik
# =============================================================================

TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_DASHBOARD_PORT=8081

# =============================================================================
# SECTION 7 — Networking: Cloudflare Tunnel (optional)
# =============================================================================
# Leave all blank if you are not using Cloudflare Tunnel.
# The setup wizard will populate these automatically when you choose Cloudflare.

CLOUDFLARE_TUNNEL_ENABLED=false
CLOUDFLARE_TUNNEL_NAME=                         # e.g. weekendstack-tunnel
CLOUDFLARE_TUNNEL_ID=                           # UUID from Cloudflare dashboard
CLOUDFLARE_TUNNEL_TOKEN=                        # Run token (auto-set by wizard)
CLOUDFLARE_API_TOKEN=                           # API token with Tunnel:Edit + DNS:Edit perms
CLOUDFLARE_ACCOUNT_ID=                          # Your Cloudflare Account ID

# =============================================================================
# SECTION 8 — Dev: Coder
# =============================================================================

CODER_HTTP_ADDRESS=0.0.0.0:7080
CODER_HTTP_PORT=7080
CODER_ACCESS_URL=http://${HOST_IP}:7080         # Set to https://coder.${BASE_DOMAIN} with Cloudflare

# Session token — generate after first login at http://HOST_IP:7080/cli-auth
CODER_SESSION_TOKEN=                            # <GENERATE after first login>

# Coder's dedicated Postgres database
POSTGRES_USER=coder
POSTGRES_PASSWORD=                              # <GENERATE> openssl rand -hex 32
POSTGRES_DB=coder
POSTGRES_MEMORY_LIMIT=512m

# =============================================================================
# SECTION 9 — Dev: Gitea
# =============================================================================

GITEA_DBNAME=gitea
GITEA_DBUSER=gitea
GITEA_DBPASS=                                   # <GENERATE> openssl rand -hex 32
GITEA_SECRET_KEY=                               # <GENERATE> openssl rand -hex 64
GITEA_INTERNAL_TOKEN=                           # <GENERATE> openssl rand -hex 64
GITEA_JWT_SECRET=                               # <GENERATE> openssl rand -hex 64
GITEA_PORT=3300
GITEA_SSH_PORT=2223
GITEA_ACTIONS_ENABLED=false
GITEA_MEMORY_LIMIT=2g

# Which git service to install alongside Coder: gitea | none
GIT_SERVICE=gitea

# =============================================================================
# SECTION 10 — Media Paths (optional path overrides)
# =============================================================================
# Leave blank to use the defaults under FILES_BASE_DIR

# Immich: where to store uploaded photos and videos
IMMICH_UPLOAD_PATH=                             # e.g. /mnt/nas/photos

# Navidrome: path to your music library
NAVIDROME_MUSIC_PATH=                           # e.g. /mnt/nas/music

# Kavita: path to your ebook/manga/comic library
KAVITA_LIBRARY_PATH=                            # e.g. /mnt/nas/books
KAVITA_API_KEY=                                 # Obtained from Kavita admin panel after first login

# =============================================================================
# SECTION 11 — NFS Storage (optional)
# =============================================================================
# Uncomment and configure if using a NAS / NFS share for media storage.

# NFS_SERVER_IP=192.168.1.3
# NFS_PHOTOS_PATH=/mnt/user/files/immich
# NFS_NAVIDROME_PATH=/mnt/user/files/navidrome
# NFS_KAVITA_PATH=/mnt/user/files/kavita

# =============================================================================
# SECTION 12 — Registry Cache
# =============================================================================
# Local pull-through cache to avoid Docker Hub rate limits during initial pull.
# setup.sh manages this automatically.

REGISTRY_PORT=5000
REGISTRY_MEMORY_LIMIT=256m
REGISTRY_DATA_DIR=${DATA_BASE_DIR}/registry-cache

# =============================================================================
# SECTION 13 — Miscellaneous
# =============================================================================

# Force link routing mode in Glance (leave blank for auto-detect)
# Options: local | external | ""
FORCE_LINK_MODE=

# Setup metadata (populated automatically by setup.sh)
SETUP_DATE=
SETUP_VERSION=
