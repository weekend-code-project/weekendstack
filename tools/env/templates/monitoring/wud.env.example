# ============================================================================
# WUD - Environment Variables
# ============================================================================

# ---------------------------------------------------------------------------
WUD_PORT=3002
WUD_WATCHER_LOCAL_CRON="0 0 * * *"
WUD_WATCHER_LOCAL_WATCHBYDEFAULT=true
# Keep updates manual by default; set true to allow one-click updates from WUD UI.
WUD_TRIGGER_DOCKER_ENABLE=false
