# ============================================================================
# NETBOX - Environment Variables
# ============================================================================

NETBOX_SUPERUSER=${DEFAULT_ADMIN_USER}
NETBOX_SUPERUSER_EMAIL=${DEFAULT_ADMIN_EMAIL}
NETBOX_SUPERUSER_PASSWORD=${DEFAULT_ADMIN_PASSWORD}
# Database
NETBOX_DB_PASSWORD=                              # <GENERATE> openssl rand -hex 32
# Security
NETBOX_SECRET_KEY=                               # <GENERATE> openssl rand -hex 64
# Server
NETBOX_PORT=8092
