# ============================================================================
# NOCODB - Environment Variables
# ============================================================================

NOCODB_ADMIN_EMAIL=${DEFAULT_ADMIN_EMAIL}
# NocoDB requires >= 8 character password; uses global DEFAULT_ADMIN_PASSWORD
NOCODB_ADMIN_PASSWORD=${DEFAULT_ADMIN_PASSWORD}
# Database
NOCODB_DBNAME=nocodb
NOCODB_DBUSER=nocodb
NOCODB_DBPASS=                                   # <GENERATE> openssl rand -hex 32
# Security Keys
NOCODB_JWT_SECRET=                               # <GENERATE> openssl rand -hex 64
NOCODB_AUTH_JWT_SECRET=                          # <GENERATE> openssl rand -hex 64
# Server
NOCODB_PORT=8083
NOCODB_MEMORY_LIMIT=1g                           # Memory limit for container
NOCODB_PUBLIC_URL=
