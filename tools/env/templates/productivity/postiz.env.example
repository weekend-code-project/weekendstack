# ============================================================================
# POSTIZ - Environment Variables
# ============================================================================

POSTIZ_ADMIN_EMAIL=${DEFAULT_ADMIN_EMAIL}
POSTIZ_ADMIN_PASSWORD=${DEFAULT_ADMIN_PASSWORD}
# Database
POSTIZ_DBNAME=postiz
POSTIZ_DBUSER=postiz
POSTIZ_DBPASS=                                   # <GENERATE> openssl rand -hex 32
# Security
POSTIZ_NEXTAUTH_SECRET=                          # <GENERATE> openssl rand -hex 64
POSTIZ_JWT_SECRET=                               # <GENERATE> openssl rand -hex 64
# Server
POSTIZ_PORT=8095
POSTIZ_MAIN_URL=
POSTIZ_FRONTEND_URL=
POSTIZ_NEXT_PUBLIC_BACKEND_URL=
POSTIZ_NEXTAUTH_URL=
POSTIZ_BASE_URL=
