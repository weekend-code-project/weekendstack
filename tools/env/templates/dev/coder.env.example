# ============================================================================
# CODER - Environment Variables
# ============================================================================

# Access Configuration
CODER_HTTP_ADDRESS=0.0.0.0:7080
CODER_HTTP_PORT=7080
CODER_ACCESS_URL=http://${HOST_IP}:7080
CODER_HOSTNAME=coder

# API Authentication
# Generate this token:
#   1. Open: http://HOST_IP:7080/cli-auth
#   2. Create your admin account (if first time)
#   3. Copy the session token displayed
#   4. Paste it below
CODER_SESSION_TOKEN=  # Required for template deployment

# Database Configuration
POSTGRES_USER=coder
POSTGRES_PASSWORD=  # <GENERATE> openssl rand -hex 32
POSTGRES_DB=coder
POSTGRES_MEMORY_LIMIT=512m