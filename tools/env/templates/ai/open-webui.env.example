# App Configuration
WEBUI_SECRET_KEY=                                # <GENERATE> openssl rand -hex 64
OPENAI_API_BASE_URL=http://localai:8080/v1
OPENAI_API_KEY=sk-local-api-key
OPENWEBUI_PORT=3000
