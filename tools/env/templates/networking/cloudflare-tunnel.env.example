# ============================================================================
# CLOUDFLARE_TUNNEL - Environment Variables
# ============================================================================

# Configure tunnel credentials in config/cloudflare/
# Set to true after tunnel setup
CLOUDFLARE_TUNNEL_ENABLED=false
# Tunnel name (e.g., weekendstack-tunnel)
CLOUDFLARE_TUNNEL_NAME=
# Your tunnel ID (UUID)
CLOUDFLARE_TUNNEL_ID=

# API Token for automated tunnel management
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account:Cloudflare Tunnel:Edit, Zone:DNS:Edit
CLOUDFLARE_API_TOKEN=

# Account ID (auto-populated by setup wizard)
CLOUDFLARE_ACCOUNT_ID=

# Tunnel run token (auto-populated by setup wizard)
# This is the token used by cloudflared to connect to Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=
