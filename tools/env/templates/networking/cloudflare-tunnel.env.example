# ============================================================================
# CLOUDFLARE_TUNNEL - Environment Variables
# ============================================================================

# Configure tunnel credentials in config/cloudflare/
CLOUDFLARE_TUNNEL_ENABLED=false                  # Set to true after tunnel setup
CLOUDFLARE_TUNNEL_NAME=                          # Tunnel name (e.g., weekendstack-tunnel)
CLOUDFLARE_TUNNEL_ID=                            # <CUSTOMIZE> Your tunnel ID (UUID)

# API Token for automated tunnel management
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Account:Cloudflare Tunnel:Edit, Zone:DNS:Edit
CLOUDFLARE_API_TOKEN=                            # <CUSTOMIZE> Your Cloudflare API token

# Account ID (auto-populated by setup wizard)
CLOUDFLARE_ACCOUNT_ID=                           # Auto-set during tunnel setup

# Advanced: Override default config/credentials paths (usually not needed)
# CLOUDFLARE_CONFIG_FILE=../config/cloudflare/config.yml
# CLOUDFLARE_CREDENTIALS_DIR=../config/cloudflare/.cloudflared
