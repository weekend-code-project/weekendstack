# ============================================================================
# SPEEDTEST_TRACKER - Environment Variables
# ============================================================================
# Speedtest Tracker - Network speed monitoring
# ============================================================================

# APP_URL is set automatically by setup.sh for Cloudflare mode.
# For local-only installs it defaults to http://<HOST_IP>:8765 in compose.
SPEEDTEST_APP_URL=
SPEEDTEST_PORT=8765
# Cron schedule for recurring speed tests (default: daily at 2am)
SPEEDTEST_SCHEDULE="0 2 * * *"
