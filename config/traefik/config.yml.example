# Traefik v3 Static Configuration
# =============================================================================
# THIS IS A TEMPLATE FILE. setup.sh copies this to config.yml on first run.
# Edit this file to change defaults for new installs.
# Edit config.yml directly to change a running instance.
# =============================================================================
log:
  level: INFO

api:
  dashboard: true
  insecure: true

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"

providers:
  docker:
    exposedByDefault: false
    endpoint: "unix:///var/run/docker.sock"
  file:
    directory: /config/traefik/auth
    watch: true
