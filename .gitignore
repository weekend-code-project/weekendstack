# =============================================================================
# SECURITY - CREDENTIALS & SECRETS
# =============================================================================
.env
*.env
!.env.example
.env.backup
.env.tmp

# Generated files (auto-created by setup.sh)
docker-compose.custom.yml
SETUP_SUMMARY.md
CLEANUP_SUMMARY.md

# Coder runtime state — must never be committed so fresh installs always deploy
config/coder/.template_deployment_complete

# Generated config files — setup.sh populates these from .example templates.
# The .example files ARE tracked; these runtime copies are not.
config/coder/scripts/deploy-all-templates.sh
config/coder/scripts/lib/
config/traefik/config.yml
config/glance/glance.yml

# Cloudflare tunnel credentials and config
config/cloudflare/.cloudflared/
config/cloudflare/*.json
config/cloudflare/*.pem
config/cloudflare/config.yml

# SSH keys and certificates
*.key
*.pem
*.crt
*.p12
*.pfx

# =============================================================================
# APPLICATION DATA & CONFIGURATIONS
# =============================================================================

# Service data and runtime files (entire files directory)
# Includes SSH keys, database data, uploads, etc.
files/

# Traefik auth secrets
# Ignore all auth/secret files, but allow non-secret dynamic config we want tracked
config/traefik/auth/*
!config/traefik/auth/dynamic-lab-catchall.yaml
!config/traefik/auth/tls.yml
!config/traefik/auth/middlewares.yml

traefik-auth/

# Pi-hole runtime state (contains DBs, tokens, hashes, etc.)
config/pihole/etc-pihole/

# Let's Encrypt certificates
letsencrypt/

# Database data
postgres_data/
config/postgres_data/

# Docker service data directories (each service has its own folder with data subdirectory)
**/data

# AI Service Data
open-webui/cache/
open-webui/vector_db/
open-webui/webui.db
ollama/models/
stable-diffusion/models/
stable-diffusion/data/
perplexica/data/
perplexica/uploads/

# Search engine configurations and backups
searxng/settings.yml.backup
searxng/settings.yml.new

# Development tools data
registry/
config/registry/
docker-run/

# =============================================================================
# DOCKER & RUNTIME
# =============================================================================
.config/

# Prevent accidental runtime data in compose/ directory
# (These should only exist at project root, not in compose/)
compose/data/
compose/config/
compose/files/
compose/git/
compose/gitea/
compose/ssh/

# =============================================================================
# SYSTEM & EDITOR FILES
# =============================================================================
.DS_Store
*.swp
*.swo
*.log
.vscode/
.idea/

# Trash and temporary files
_trash/
*.tmp
*.bak
*.backupdata/

# SMB/Network share temporary files
.smbdelete*

# =============================================================================
# CODER TEMPLATE SYSTEM - BUILD ARTIFACTS & RUNTIME STATE
# =============================================================================

# Vendored modules copied into templates at push time (ephemeral)
config/coder/templates/*/modules/

# Staging and dist directories (build artifacts)
config/coder/.staging/
config/coder/staging/
config/coder/**/staging/
config/coder/dist/

# Build artifacts and lock files
config/coder/templates/*/*.lock.tmp
config/coder/templates/*/modules_manifest.*.json

# Version tracking files (auto-generated by push script)
config/coder/.versions.json
config/coder/**/.version
config/coder/scripts/.template_versions.json